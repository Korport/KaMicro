# ─── Server ───────────────────────────────────────────────────
# TCP port the Node server listens on (Caddy proxies to this)
PORT=3001

# Public URL used to generate QR codes — must match your Caddyfile domain
# Include protocol: https://yourdomain.com  (no trailing slash)
DOMAIN=http://localhost:5173

# ─── GIPHY ────────────────────────────────────────────────────
# Create a free API key at https://developers.giphy.com/
GIPHY_API_KEY=your_giphy_api_key_here
